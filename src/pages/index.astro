---
export const prerender = false;

import { env } from "cloudflare:workers";
import { Archive, ArrowRight, BookOpen, BriefcaseBusiness, CalendarDays, Landmark, MapPinned, MessageCircle, PanelsTopLeft, RotateCcw, ShieldCheck, Sparkles } from "lucide-astro";
import Base from "../layouts/Base.astro";
import { createDb } from "../db/client";
import { getContentStats, getTodayCategoryCounts, listArchiveDays, listRecentAiDiscoveries, listRecentDistrictBriefs, listRecentVisualGuides, listTodayContentItems } from "../lib/content";
import { CATEGORY_DESCRIPTIONS, CATEGORY_GROUPS, CATEGORY_LABELS, categoryLabel, type Category } from "../lib/categories";
import { formatKstDate, formatShortDate, todayKstRange } from "../lib/dates";
import { excerpt } from "../lib/text";

const db = createDb(env.DB);
const categoryParam = Astro.url.searchParams.get("category");
const activeCategory = (categoryParam && categoryParam in CATEGORY_LABELS ? categoryParam : undefined) as Category | undefined;
const now = new Date();
const today = todayKstRange(now);
const [items, stats, archiveDays, visualGuides, aiDiscoveries, categoryCountRows, districtBriefs] = await Promise.all([
  listTodayContentItems(db, activeCategory, now),
  getContentStats(db, now),
  listArchiveDays(db, now, 3),
  listRecentVisualGuides(db, activeCategory, 3, today.start),
  listRecentAiDiscoveries(db, activeCategory, 4, today.start),
  getTodayCategoryCounts(db, now),
  listRecentDistrictBriefs(db, 3, today.start),
]);

// Cached at the edge: content only changes on the 6-hourly ingestion cron, so
// repeat visits within the window can be served without hitting D1 again.
Astro.response.headers.set("cache-control", "public, max-age=90, stale-while-revalidate=600");

const todayCategoryCounts = new Map(categoryCountRows.map(({ category, count }) => [category, count]));
const groupIcons = {
  "money-home": Landmark,
  "work-rights": BriefcaseBusiness,
  "safe-life": ShieldCheck,
  "culture-break": Sparkles,
};
const featured = items[0];
const feedItems = items.slice(1);
const hasSidebarContent = visualGuides.length > 0 || (!activeCategory && districtBriefs.length > 0) || aiDiscoveries.length > 0;
---

<Base title="읽고, 묻고, 오래 기억하는 생활 상식">
  <section class="hero" aria-labelledby="hero-title">
    <div class="hero-image" aria-hidden="true"></div>
    <div class="hero-content shell">
      <p class="hero-kicker"><Sparkles size={16} /> 오늘의 생활력 한 칸</p>
      <h1 id="hero-title">사회초년생을 위한<br />생활 상식</h1>
      <p>막막할 때 찾아보고, 궁금하면 바로 묻고, 잊을 때쯤 다시 만나요.</p>
      <div class="hero-actions">
        <a class="button button-primary" href="/review">
          <RotateCcw size={17} /> 오늘 복습하기
        </a>
        <a class="button button-secondary" href="/chat">
          <MessageCircle size={17} /> 라이프 메이트에게 묻기
        </a>
      </div>
    </div>
  </section>

  <div class="shell home-layout">
    <div class="home-main">
      <section class="category-section" aria-labelledby="category-title">
        <div class="section-heading">
          <div>
            <p class="eyebrow">KNOWLEDGE MAP</p>
            <h2 id="category-title">오늘의 지식 지도</h2>
          </div>
          <span class="content-count">오늘 {stats.today}개 · 누적 {stats.total}개</span>
        </div>

        <nav class="topic-map" aria-label="콘텐츠 분야">
          <a class:list={["all-topics", { active: !activeCategory }]} href="/" aria-current={!activeCategory ? "page" : undefined}>
            <span>모든 주제</span><strong>{stats.today}</strong>
          </a>
          {CATEGORY_GROUPS.map((group) => {
            const GroupIcon = groupIcons[group.id];
            return (
              <section class="topic-group" aria-labelledby={`group-${group.id}`}>
                <header>
                  <span class="topic-group-icon" aria-hidden="true"><GroupIcon size={19} /></span>
                  <span>
                    <strong id={`group-${group.id}`}>{group.label}</strong>
                    <small>{group.description}</small>
                  </span>
                </header>
                <div class="topic-links">
                  {group.categories.map((category) => (
                    <a
                      class:list={["topic-link", { active: activeCategory === category }]}
                      href={`/?category=${category}`}
                      aria-current={activeCategory === category ? "page" : undefined}
                    >
                      <span class="category-swatch" data-category={category}></span>
                      <span><strong>{CATEGORY_LABELS[category]}</strong><small>{CATEGORY_DESCRIPTIONS[category]}</small></span>
                      <b>{todayCategoryCounts.get(category) ?? 0}</b>
                    </a>
                  ))}
                </div>
              </section>
            );
          })}
        </nav>
      </section>

      {featured ? (
        <>
          <section class="featured-section" aria-labelledby="featured-title">
            <div class="section-heading">
              <div>
                <p class="eyebrow">NEW KNOWLEDGE</p>
                <h2 id="featured-title">오늘 가장 최근에 도착한 상식</h2>
              </div>
            </div>

            <a class="featured-story" href={`/articles/${featured.id}`}>
              <div class="featured-number" aria-hidden="true">01</div>
              <div class="featured-copy">
                <div class="featured-tags">
                  <span class="category-label" data-category={featured.category}>{categoryLabel(featured.category)}</span>
                  {featured.contentFormat === "visual_guide" && <span class="visual-format-badge"><PanelsTopLeft size={13} /> 4컷 용어</span>}
                </div>
                <h3>{featured.title}</h3>
                <p>{featured.cards?.[0]?.body ?? excerpt(featured.bodyMd, 150)}</p>
                <span class="story-meta">{featured.citationLabel} · {formatShortDate(featured.createdAt)}</span>
              </div>
              <span class="story-arrow" aria-hidden="true"><ArrowRight size={23} /></span>
            </a>
          </section>

          {feedItems.length > 0 && (
            <section class="feed-section" aria-labelledby="feed-title">
              <div class="section-heading">
                <div>
                  <p class="eyebrow">KNOWLEDGE FEED</p>
                  <h2 id="feed-title">오늘 차곡차곡 쌓인 상식</h2>
                </div>
              </div>

              <ul class="content-grid">
                {feedItems.map((item, index) => (
                  <li>
                    <a class="content-card" href={`/articles/${item.id}`}>
                      <div class="card-topline">
                        <div class="card-tags">
                          <span class="category-label" data-category={item.category}>{categoryLabel(item.category)}</span>
                          {item.contentFormat === "visual_guide" && <span class="visual-format-badge"><PanelsTopLeft size={13} /> 4컷 용어</span>}
                        </div>
                        <span class="card-number">{String(index + 2).padStart(2, "0")}</span>
                      </div>
                      <h3>{item.title}</h3>
                      <p>{item.cards?.[0]?.body ?? excerpt(item.bodyMd)}</p>
                      <div class="card-footer">
                        <span>{item.citationLabel}</span>
                        <span>{formatShortDate(item.createdAt)}</span>
                      </div>
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          )}
        </>
      ) : (
        <section class="empty-state" aria-labelledby="empty-title">
          <BookOpen size={34} strokeWidth={1.7} />
          <h2 id="empty-title">오늘 이 분야에 도착한 상식은 아직 없어요</h2>
          <p>지난 상식 보관함에서 이전 자료를 찾아볼 수 있어요.</p>
          <a class="button button-primary" href="/archive"><Archive size={17} /> 지난 상식 보기</a>
        </section>
      )}
    </div>

    <aside class="home-sidebar" aria-label="더 둘러보기">
      {hasSidebarContent && (
        <div class="sidebar-card">
          <div class="sidebar-card-heading">
            <p class="eyebrow">EXPLORE MORE</p>
            <h2>오늘 함께 볼 만한 것들</h2>
          </div>

          {visualGuides.length > 0 && (
            <div class="sidebar-group">
              <div class="sidebar-group-heading">
                <span><PanelsTopLeft size={15} /> 시작 코스 용어</span>
                <a href="/start">전체 보기 <ArrowRight size={13} /></a>
              </div>
              <ul class="rail-list">
                {visualGuides.map((guide) => (
                  <li>
                    <a href={`/articles/${guide.id}`} data-category={guide.category}>
                      <span class="rail-icon"><PanelsTopLeft size={16} /></span>
                      <span class="rail-copy">
                        <strong>{guide.title}</strong>
                        <small>{guide.cards?.[0]?.body ?? excerpt(guide.bodyMd, 60)}</small>
                      </span>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}

          {!activeCategory && districtBriefs.length > 0 && (
            <div class="sidebar-group">
              <div class="sidebar-group-heading">
                <span><MapPinned size={15} /> 서울 자치구 브리핑</span>
                <a href="/archive?category=seoul_life">더 보기 <ArrowRight size={13} /></a>
              </div>
              <ul class="rail-list">
                {districtBriefs.map((item) => (
                  <li>
                    <a href={`/articles/${item.id}`} data-category={item.category}>
                      <span class="rail-icon"><MapPinned size={16} /></span>
                      <span class="rail-copy">
                        <strong>{item.title}</strong>
                        <small>{item.cards?.[0]?.body ?? excerpt(item.bodyMd, 60)}</small>
                      </span>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}

          {aiDiscoveries.length > 0 && (
            <div class="sidebar-group">
              <div class="sidebar-group-heading">
                <span><Sparkles size={15} /> 큐레이션 상식</span>
                <a href="/archive?source=ai_trivia">더 보기 <ArrowRight size={13} /></a>
              </div>
              <ul class="rail-list">
                {aiDiscoveries.map((item) => (
                  <li>
                    <a href={`/articles/${item.id}`} data-category={item.category}>
                      <span class="category-label" data-category={item.category}>{categoryLabel(item.category)}</span>
                      <span class="rail-copy">
                        <strong>{item.title}</strong>
                        <small>{item.cards?.[0]?.body ?? excerpt(item.bodyMd, 60)}</small>
                      </span>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>
      )}

      <a class="sidebar-card archive-card" href="/archive">
        <div class="archive-card-heading">
          <Archive size={20} />
          <div><span>00시 이전 상식은 보관함에서</span><strong>{stats.archive}개 계속 탐색하기</strong></div>
        </div>
        {archiveDays.length > 0 && (
          <div class="archive-days">
            {archiveDays.map((day) => (
              <span><CalendarDays size={13} /> {formatKstDate(day.day, false)} · {day.count}</span>
            ))}
          </div>
        )}
        <span class="archive-card-cta">전체 보관함 보기 <ArrowRight size={15} /></span>
      </a>
    </aside>
  </div>
</Base>

<style>
  .hero {
    position: relative;
    min-height: 340px;
    overflow: hidden;
    isolation: isolate;
    background: #eef2ef;
    border-bottom: 1px solid var(--line);
  }

  .hero-image {
    position: absolute;
    inset: 0;
    z-index: -1;
    background-image: url("/images/life-quiz-desk.webp");
    background-position: center;
    background-size: cover;
  }

  .hero-content {
    min-height: 340px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
  }

  .hero-kicker {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin: 0 0 12px;
    color: var(--green-deep);
    font-size: 0.82rem;
    font-weight: 800;
  }

  .hero h1 {
    margin: 0;
    font-size: clamp(2.2rem, 4.4vw, 3.8rem);
    line-height: 1.07;
  }

  .hero-content > p:not(.hero-kicker) {
    max-width: 470px;
    margin: 16px 0 0;
    color: var(--muted-strong);
    font-size: 1rem;
  }

  .hero-actions {
    display: flex;
    gap: 10px;
    margin-top: 24px;
  }

  .home-layout {
    padding-top: 40px;
    padding-bottom: 12px;
    display: grid;
    grid-template-columns: minmax(0, 1fr) 340px;
    align-items: start;
    gap: 32px;
  }

  .home-main {
    min-width: 0;
  }

  .home-sidebar {
    position: sticky;
    top: 88px;
    display: grid;
    gap: 16px;
  }

  .category-section,
  .featured-section,
  .feed-section {
    margin-bottom: 40px;
  }

  .content-count {
    color: var(--muted);
    font-size: 0.82rem;
    font-weight: 700;
  }

  .topic-map {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1px;
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    background: var(--line);
  }

  .all-topics {
    grid-column: 1 / -1;
    min-height: 48px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 18px;
    color: var(--ink);
    background: var(--paper);
    text-decoration: none;
    font-size: 0.88rem;
    font-weight: 800;
  }

  .all-topics strong {
    min-width: 28px;
    color: var(--green);
    text-align: right;
  }

  .all-topics.active {
    color: white;
    background: var(--ink);
  }

  .all-topics.active strong { color: #c5ddd2; }

  .topic-group {
    min-width: 0;
    padding: 16px;
    background: var(--paper);
  }

  .topic-group > header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 12px;
  }

  .topic-group-icon {
    width: 36px;
    height: 36px;
    display: grid;
    place-items: center;
    flex: 0 0 36px;
    border-radius: var(--radius-sm);
    color: var(--green-deep);
    background: var(--green-soft);
  }

  .topic-group > header > span:last-child {
    min-width: 0;
    display: grid;
  }

  .topic-group > header strong { font-size: 0.92rem; }
  .topic-group > header small { color: var(--muted); font-size: 0.72rem; }

  .topic-links {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 6px;
  }

  .topic-link {
    min-width: 0;
    min-height: 54px;
    display: grid;
    grid-template-columns: 8px minmax(0, 1fr) 24px;
    align-items: center;
    gap: 9px;
    padding: 8px 10px;
    border-radius: var(--radius-sm);
    color: var(--ink);
    background: var(--surface);
    text-decoration: none;
  }

  .topic-link:hover,
  .topic-link.active {
    background: var(--surface-strong);
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--green) 25%, var(--line));
  }

  .topic-link > span:nth-child(2) {
    min-width: 0;
    display: grid;
  }

  .topic-link strong,
  .topic-link small {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .topic-link strong { font-size: 0.79rem; }
  .topic-link small { color: var(--muted); font-size: 0.67rem; }
  .topic-link b { color: var(--muted); font-size: 0.73rem; text-align: right; }

  .featured-story {
    min-height: 210px;
    display: grid;
    grid-template-columns: 100px minmax(0, 1fr) 46px;
    align-items: stretch;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--green) 25%, var(--line));
    border-radius: var(--radius-md);
    background: var(--green-soft);
    color: var(--ink);
    text-decoration: none;
    box-shadow: var(--shadow-sm);
  }

  .featured-number {
    display: grid;
    place-items: center;
    background: var(--green);
    color: white;
    font-size: 2rem;
    font-weight: 850;
  }

  .featured-copy {
    align-self: center;
    padding: 30px 34px;
  }

  .featured-tags,
  .card-tags {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
  }

  .featured-copy h3 {
    max-width: 640px;
    margin: 10px 0 10px;
    font-size: clamp(1.3rem, 2.2vw, 1.8rem);
    line-height: 1.3;
  }

  .featured-copy p {
    max-width: 620px;
    margin: 0 0 16px;
    color: var(--muted-strong);
  }

  .story-meta,
  .card-footer {
    color: var(--muted);
    font-size: 0.77rem;
    font-weight: 650;
  }

  .story-arrow {
    display: grid;
    place-items: center;
    color: var(--green-deep);
  }

  .featured-story:hover .story-arrow {
    transform: translateX(3px);
  }

  .content-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .content-grid li {
    min-width: 0;
  }

  .content-card {
    min-height: 220px;
    height: 100%;
    display: flex;
    flex-direction: column;
    padding: 20px;
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    background: var(--paper);
    color: var(--ink);
    text-decoration: none;
    box-shadow: var(--shadow-sm);
    transition: transform 160ms ease, border-color 160ms ease, box-shadow 160ms ease;
  }

  .content-card:hover {
    transform: translateY(-3px);
    border-color: color-mix(in srgb, var(--green) 35%, var(--line));
    box-shadow: 0 10px 28px rgba(22, 34, 28, 0.09);
  }

  .card-topline,
  .card-footer {
    display: flex;
    justify-content: space-between;
    gap: 12px;
  }

  .card-number {
    color: var(--line);
    font-size: 0.82rem;
    font-weight: 850;
  }

  .content-card h3 {
    margin: 16px 0 9px;
    font-size: 1.02rem;
    line-height: 1.42;
  }

  .content-card > p {
    display: -webkit-box;
    margin: 0 0 18px;
    overflow: hidden;
    color: var(--muted-strong);
    font-size: 0.85rem;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
  }

  .card-footer {
    margin-top: auto;
    padding-top: 13px;
    border-top: 1px solid var(--line);
  }

  .card-footer span:first-child {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .empty-state {
    display: grid;
    justify-items: center;
    padding: 70px 20px;
    border: 1px dashed color-mix(in srgb, var(--green) 35%, var(--line));
    border-radius: var(--radius-md);
    background: var(--paper);
    text-align: center;
  }

  .empty-state h2 {
    margin: 16px 0 6px;
    font-size: 1.2rem;
  }

  .empty-state p {
    margin: 0 0 22px;
    color: var(--muted);
  }

  .sidebar-card {
    padding: 20px;
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    background: var(--paper);
  }

  .sidebar-card-heading {
    margin-bottom: 16px;
  }

  .sidebar-card-heading h2 {
    margin: 0;
    font-size: 1.02rem;
  }

  .sidebar-group + .sidebar-group {
    margin-top: 20px;
    padding-top: 18px;
    border-top: 1px solid var(--line);
  }

  .sidebar-group-heading {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    margin-bottom: 10px;
  }

  .sidebar-group-heading > span {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--muted-strong);
    font-size: 0.76rem;
    font-weight: 800;
  }

  .sidebar-group-heading a {
    display: inline-flex;
    align-items: center;
    gap: 3px;
    color: var(--green-deep);
    font-size: 0.7rem;
    font-weight: 750;
    text-decoration: none;
    white-space: nowrap;
  }

  .rail-list {
    display: grid;
    gap: 4px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .rail-list a {
    min-width: 0;
    display: grid;
    grid-template-columns: 30px minmax(0, 1fr);
    align-items: center;
    gap: 10px;
    padding: 8px;
    border-radius: var(--radius-sm);
    color: var(--ink);
    text-decoration: none;
  }

  .rail-list a:hover {
    background: var(--surface-strong);
  }

  .rail-icon {
    width: 30px;
    height: 30px;
    display: grid;
    place-items: center;
    border-radius: var(--radius-sm);
    color: var(--category-color, var(--green-deep));
    background: var(--category-soft, var(--green-soft));
  }

  .rail-list .category-label {
    align-self: start;
    margin-top: 2px;
  }

  .rail-copy {
    min-width: 0;
    display: grid;
    gap: 2px;
  }

  .rail-copy strong {
    overflow: hidden;
    font-size: 0.83rem;
    line-height: 1.35;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .rail-copy small {
    display: -webkit-box;
    overflow: hidden;
    color: var(--muted);
    font-size: 0.72rem;
    line-height: 1.4;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  .archive-card {
    display: grid;
    gap: 12px;
    color: white;
    background: var(--ink);
    text-decoration: none;
  }

  .archive-card-heading {
    display: grid;
    grid-template-columns: 24px minmax(0, 1fr);
    align-items: center;
    gap: 10px;
  }

  .archive-card-heading > svg {
    color: #9bd0b9;
  }

  .archive-card-heading div {
    display: grid;
    gap: 2px;
  }

  .archive-card-heading span {
    color: #b8c3bd;
    font-size: 0.72rem;
  }

  .archive-card-heading strong {
    font-size: 0.94rem;
    line-height: 1.35;
  }

  .archive-days {
    display: grid;
    gap: 4px;
  }

