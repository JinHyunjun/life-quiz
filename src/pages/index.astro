---
export const prerender = false;

import { env } from "cloudflare:workers";
import { Archive, ArrowRight, BookOpen, CalendarDays, MessageCircle, PanelsTopLeft, RotateCcw, Sparkles } from "lucide-astro";
import Base from "../layouts/Base.astro";
import { createDb } from "../db/client";
import { getContentStats, listArchiveDays, listRecentVisualGuides, listTodayContentItems } from "../lib/content";
import { CATEGORY_LABELS, categoryLabel, type Category } from "../lib/categories";
import { formatKstDate } from "../lib/dates";

const db = createDb(env.DB);
const categoryParam = Astro.url.searchParams.get("category");
const activeCategory = (categoryParam && categoryParam in CATEGORY_LABELS ? categoryParam : undefined) as Category | undefined;
const [items, stats, archiveDays, visualGuides] = await Promise.all([
  listTodayContentItems(db, activeCategory),
  getContentStats(db),
  listArchiveDays(db, new Date(), 3),
  listRecentVisualGuides(db, activeCategory, 3),
]);
const featured = items[0];
const feedItems = items.slice(1);

function excerpt(bodyMd: string, maxLength = 110) {
  const plain = bodyMd.replace(/[#*_>`\[\]]/g, "").replace(/\s+/g, " ").trim();
  return plain.length > maxLength ? `${plain.slice(0, maxLength).trim()}...` : plain;
}

function formatDate(value: Date) {
  return new Intl.DateTimeFormat("ko-KR", { month: "short", day: "numeric" }).format(value);
}
---

<Base title="읽고, 묻고, 오래 기억하는 생활 상식">
  <section class="hero" aria-labelledby="hero-title">
    <div class="hero-image" aria-hidden="true"></div>
    <div class="hero-content shell">
      <p class="hero-kicker"><Sparkles size={16} /> 오늘의 생활력 한 칸</p>
      <h1 id="hero-title">사회초년생을 위한<br />생활 상식</h1>
      <p>막막할 때 찾아보고, 궁금하면 바로 묻고, 잊을 때쯤 다시 만나요.</p>
      <div class="hero-actions">
        <a class="button button-primary" href="/review">
          <RotateCcw size={17} /> 오늘 복습하기
        </a>
        <a class="button button-secondary" href="/chat">
          <MessageCircle size={17} /> 라이프 메이트에게 묻기
        </a>
      </div>
    </div>
  </section>

  <div class="shell home-content">
    <section class="category-section" aria-labelledby="category-title">
      <div class="section-heading">
        <div>
          <p class="eyebrow">EXPLORE</p>
          <h2 id="category-title">지금 필요한 분야부터</h2>
        </div>
        <span class="content-count">오늘 {stats.today}개 · 누적 {stats.total}개</span>
      </div>

      <nav class="category-tabs" aria-label="콘텐츠 분야">
        <a class:list={["category-tab", { active: !activeCategory }]} href="/" aria-current={!activeCategory ? "page" : undefined}>
          전체
        </a>
        {Object.entries(CATEGORY_LABELS).map(([key, label]) => (
          <a
            class:list={["category-tab", { active: activeCategory === key }]}
            href={`/?category=${key}`}
            aria-current={activeCategory === key ? "page" : undefined}
          >
            <span class="tab-swatch" data-category={key}></span>{label}
          </a>
        ))}
      </nav>
    </section>

    {visualGuides.length > 0 && (
      <section class="glossary-section" aria-labelledby="glossary-title">
        <div class="section-heading">
          <div>
            <p class="eyebrow">STARTER GLOSSARY</p>
            <h2 id="glossary-title">처음 배우는 금융·투자·부동산 용어</h2>
          </div>
          <a class="glossary-note" href="/start">전체 시작 코스 <ArrowRight size={16} /></a>
        </div>
        <div class="glossary-grid">
          {visualGuides.map((guide) => (
            <a class="glossary-card" href={`/articles/${guide.id}`} data-category={guide.category}>
              <span class="glossary-icon"><PanelsTopLeft size={28} /></span>
              <span class="glossary-copy">
                <span class="category-label" data-category={guide.category}>{categoryLabel(guide.category)}</span>
                <strong>{guide.title}</strong>
                <small>{guide.cards?.[0]?.body ?? excerpt(guide.bodyMd, 90)}</small>
              </span>
              <ArrowRight size={19} />
            </a>
          ))}
        </div>
      </section>
    )}

    {featured ? (
      <>
        <section class="featured-section" aria-labelledby="featured-title">
          <div class="section-heading">
            <div>
              <p class="eyebrow">NEW KNOWLEDGE</p>
              <h2 id="featured-title">오늘 가장 최근에 도착한 상식</h2>
            </div>
          </div>

          <a class="featured-story" href={`/articles/${featured.id}`}>
            <div class="featured-number" aria-hidden="true">01</div>
            <div class="featured-copy">
              <div class="featured-tags">
                <span class="category-label" data-category={featured.category}>{categoryLabel(featured.category)}</span>
                {featured.contentFormat === "visual_guide" && <span class="visual-format-badge"><PanelsTopLeft size={13} /> 4컷 용어</span>}
              </div>
              <h3>{featured.title}</h3>
              <p>{featured.cards?.[0]?.body ?? excerpt(featured.bodyMd, 150)}</p>
              <span class="story-meta">{featured.citationLabel} · {formatDate(featured.createdAt)}</span>
            </div>
            <span class="story-arrow" aria-hidden="true"><ArrowRight size={23} /></span>
          </a>
        </section>

        {feedItems.length > 0 && (
          <section class="feed-section" aria-labelledby="feed-title">
            <div class="section-heading">
              <div>
                <p class="eyebrow">KNOWLEDGE FEED</p>
                <h2 id="feed-title">오늘 차곡차곡 쌓인 상식</h2>
              </div>
            </div>

            <ul class="content-grid">
              {feedItems.map((item, index) => (
                <li>
                  <a class="content-card" href={`/articles/${item.id}`}>
                    <div class="card-topline">
                      <div class="card-tags">
                        <span class="category-label" data-category={item.category}>{categoryLabel(item.category)}</span>
                        {item.contentFormat === "visual_guide" && <span class="visual-format-badge"><PanelsTopLeft size={13} /> 4컷 용어</span>}
                      </div>
                      <span class="card-number">{String(index + 2).padStart(2, "0")}</span>
                    </div>
                    <h3>{item.title}</h3>
                    <p>{item.cards?.[0]?.body ?? excerpt(item.bodyMd)}</p>
                    <div class="card-footer">
                      <span>{item.citationLabel}</span>
                      <span>{formatDate(item.createdAt)}</span>
                    </div>
                  </a>
                </li>
              ))}
            </ul>
          </section>
        )}
      </>
    ) : (
      <section class="empty-state" aria-labelledby="empty-title">
        <BookOpen size={34} strokeWidth={1.7} />
        <h2 id="empty-title">오늘 이 분야에 도착한 상식은 아직 없어요</h2>
        <p>지난 상식 보관함에서 이전 자료를 찾아볼 수 있어요.</p>
        <a class="button button-primary" href="/archive"><Archive size={17} /> 지난 상식 보기</a>
      </section>
    )}

    <section class="archive-band" aria-labelledby="archive-title">
      <div class="archive-band-icon" aria-hidden="true"><Archive size={26} /></div>
      <div class="archive-band-copy">
        <p class="eyebrow">BEFORE TODAY</p>
        <h2 id="archive-title">00시 이전 상식은 보관함에서</h2>
        <p>날짜, 분야, 출처별로 나눠서 이전 데이터 {stats.archive}개를 계속 탐색할 수 있어요.</p>
      </div>
      {archiveDays.length > 0 && (
        <div class="archive-days" aria-label="최근 보관 날짜">
          {archiveDays.map((day) => (
            <a href={`/archive?date=${day.day}`}>
              <CalendarDays size={15} />
              <span>{formatKstDate(day.day, false)}</span>
              <strong>{day.count}</strong>
            </a>
          ))}
        </div>
      )}
      <a class="button button-secondary archive-button" href="/archive">
        전체 보관함 <ArrowRight size={17} />
      </a>
    </section>
  </div>
</Base>

<style>
  .hero {
    position: relative;
    min-height: 390px;
    overflow: hidden;
    isolation: isolate;
    background: #eef2ef;
    border-bottom: 1px solid var(--line);
  }

  .hero-image {
    position: absolute;
    inset: 0;
    z-index: -1;
    background-image: url("/images/life-quiz-desk.webp");
    background-position: center;
    background-size: cover;
  }

  .hero-content {
    min-height: 390px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
  }

  .hero-kicker {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin: 0 0 12px;
    color: var(--green-deep);
    font-size: 0.82rem;
    font-weight: 800;
  }

  .hero h1 {
    margin: 0;
    font-size: clamp(2.4rem, 5vw, 4.5rem);
    line-height: 1.07;
  }

  .hero-content > p:not(.hero-kicker) {
    max-width: 470px;
    margin: 18px 0 0;
    color: var(--muted-strong);
    font-size: 1rem;
  }

  .hero-actions {
    display: flex;
    gap: 10px;
    margin-top: 26px;
  }

  .home-content {
    padding-top: 46px;
  }

  .category-section,
  .featured-section,
  .feed-section {
    margin-bottom: 50px;
  }

  .content-count {
    color: var(--muted);
    font-size: 0.82rem;
    font-weight: 700;
  }

  .category-tabs {
    display: flex;
    gap: 8px;
    overflow-x: auto;
    padding: 2px 2px 8px;
    scrollbar-width: none;
  }

  .category-tabs::-webkit-scrollbar {
    display: none;
  }

  .category-tab {
    min-height: 38px;
    display: inline-flex;
    align-items: center;
    gap: 7px;
    flex: 0 0 auto;
    padding: 0 13px;
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    background: var(--paper);
    color: var(--muted-strong);
    text-decoration: none;
    font-size: 0.84rem;
    font-weight: 700;
  }

  .category-tab:hover,
  .category-tab.active {
    color: white;
    border-color: var(--ink);
    background: var(--ink);
  }

  .tab-swatch {
    width: 8px;
    height: 8px;
    border-radius: 2px;
    background: var(--green);
  }

  .tab-swatch[data-category="housing"] { background: var(--coral); }
  .tab-swatch[data-category="investment"] { background: var(--berry); }
  .tab-swatch[data-category="seoul_life"] { background: var(--blue); }
  .tab-swatch[data-category="daily_tips"] { background: var(--yellow); }
  .tab-swatch[data-category="history"] { background: #7b5ca8; }
  .tab-swatch[data-category="humor"] { background: #d66a29; }
  .tab-swatch[data-category="social_skills"] { background: #277e8e; }

  .featured-story {
    min-height: 230px;
    display: grid;
    grid-template-columns: 110px minmax(0, 1fr) 46px;
    align-items: stretch;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--green) 25%, var(--line));
    border-radius: var(--radius-md);
    background: var(--green-soft);
    color: var(--ink);
    text-decoration: none;
    box-shadow: var(--shadow-sm);
  }

  .featured-number {
    display: grid;
    place-items: center;
    background: var(--green);
    color: white;
    font-size: 2rem;
    font-weight: 850;
  }

  .featured-copy {
    align-self: center;
    padding: 34px 38px;
  }

  .featured-tags,
  .card-tags {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
  }

  .glossary-section {
    margin-bottom: 52px;
    padding: 24px;
    border: 1px solid #d8ce94;
    border-radius: var(--radius-md);
    background: #fffbdf;
  }

  .glossary-section .section-heading {
    margin-bottom: 16px;
  }

  .glossary-note {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: #695a0a;
    font-size: 0.76rem;
    font-weight: 800;
    text-decoration: none;
  }

  .glossary-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
  }

  .glossary-card {
    min-width: 0;
    display: grid;
    grid-template-columns: 58px minmax(0, 1fr) 22px;
    align-items: center;
    gap: 14px;
    padding: 16px;
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    color: var(--ink);
    background: var(--paper);
    text-decoration: none;
    transition: transform 160ms ease, border-color 160ms ease;
  }

  .glossary-card:hover {
    transform: translateY(-2px);
    border-color: #b4a54c;
  }

  .glossary-icon {
    width: 58px;
    height: 58px;
    display: grid;
    place-items: center;
    border-radius: var(--radius-md);
    color: var(--green-deep);
    background: var(--green-soft);
  }

  .glossary-card[data-category="housing"] .glossary-icon {
    color: var(--coral);
    background: var(--coral-soft);
  }

  .glossary-card[data-category="investment"] .glossary-icon {
    color: var(--berry);
    background: var(--berry-soft);
  }

  .glossary-copy {
    min-width: 0;
    display: grid;
    gap: 4px;
  }

  .glossary-copy strong,
  .glossary-copy small {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .glossary-copy strong {
    font-size: 0.96rem;
  }

  .glossary-copy small {
    color: var(--muted);
    font-size: 0.75rem;
  }

  .featured-copy h3 {
    max-width: 750px;
    margin: 10px 0 10px;
    font-size: clamp(1.35rem, 2.5vw, 2rem);
    line-height: 1.3;
  }

  .featured-copy p {
    max-width: 720px;
    margin: 0 0 18px;
    color: var(--muted-strong);
  }

  .story-meta,
  .card-footer {
    color: var(--muted);
    font-size: 0.77rem;
    font-weight: 650;
  }

  .story-arrow {
    display: grid;
    place-items: center;
    color: var(--green-deep);
  }

  .featured-story:hover .story-arrow {
    transform: translateX(3px);
  }

  .content-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .content-grid li {
    min-width: 0;
  }

  .content-card {
    min-height: 242px;
    height: 100%;
    display: flex;
    flex-direction: column;
    padding: 22px;
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    background: var(--paper);
    color: var(--ink);
    text-decoration: none;
    box-shadow: var(--shadow-sm);
    transition: transform 160ms ease, border-color 160ms ease, box-shadow 160ms ease;
  }

  .content-card:hover {
    transform: translateY(-3px);
    border-color: color-mix(in srgb, var(--green) 35%, var(--line));
    box-shadow: 0 10px 28px rgba(22, 34, 28, 0.09);
  }

  .card-topline,
  .card-footer {
    display: flex;
    justify-content: space-between;
    gap: 12px;
  }

  .card-number {
    color: var(--line);
    font-size: 0.82rem;
    font-weight: 850;
  }

  .content-card h3 {
    margin: 18px 0 10px;
    font-size: 1.08rem;
    line-height: 1.42;
  }

  .content-card > p {
    display: -webkit-box;
    margin: 0 0 22px;
    overflow: hidden;
    color: var(--muted-strong);
    font-size: 0.87rem;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
  }

  .card-footer {
    margin-top: auto;
    padding-top: 14px;
    border-top: 1px solid var(--line);
  }

  .card-footer span:first-child {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .empty-state {
    display: grid;
    justify-items: center;
    padding: 70px 20px;
    border: 1px dashed color-mix(in srgb, var(--green) 35%, var(--line));
    border-radius: var(--radius-md);
    background: var(--paper);
    text-align: center;
  }

  .empty-state h2 {
    margin: 16px 0 6px;
    font-size: 1.2rem;
  }

  .empty-state p {
    margin: 0 0 22px;
    color: var(--muted);
  }

  .archive-band {
    display: grid;
    grid-template-columns: 52px minmax(240px, 1fr) minmax(220px, auto) auto;
    align-items: center;
    gap: 20px;
    margin: 0 0 12px;
    padding: 24px;
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    background: var(--ink);
    color: white;
  }

  .archive-band-icon {
    width: 52px;
    height: 52px;
    display: grid;
    place-items: center;
    border-radius: var(--radius-md);
    color: var(--green-deep);
    background: #a9d8c4;
  }

  .archive-band .eyebrow {
    color: #9bd0b9;
  }

  .archive-band h2 {
    margin: 0;
    font-size: 1.15rem;
  }

  .archive-band-copy > p:last-child {
    margin: 4px 0 0;
    color: #b8c3bd;
    font-size: 0.8rem;
  }

  .archive-days {
    display: flex;
    gap: 6px;
  }

  .archive-days a {
    min-height: 42px;
    display: grid;
    grid-template-columns: 16px auto;
    align-items: center;
    gap: 2px 6px;
    padding: 6px 9px;
    border: 1px solid #3d4a44;
    border-radius: var(--radius-sm);
    color: #dbe4df;
    text-decoration: none;
    font-size: 0.68rem;
  }

  .archive-days strong {
    grid-column: 2;
    color: white;
    font-size: 0.72rem;
  }

  .archive-button {
    white-space: nowrap;
  }

  @media (max-width: 900px) {
    .hero-image {
      opacity: 0.48;
    }

    .content-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .archive-band {
      grid-template-columns: 52px minmax(0, 1fr) auto;
    }

    .archive-days {
      display: none;
    }
  }

  @media (max-width: 620px) {
    .glossary-section {
      padding: 18px;
    }

    .glossary-grid {
      grid-template-columns: 1fr;
    }

    .glossary-note {
      display: none;
    }

    .hero,
    .hero-content {
      min-height: 430px;
    }

    .hero-image {
      background-position: 62% center;
      opacity: 0.3;
    }

    .hero h1 {
      font-size: 2.35rem;
    }

    .hero-content > p:not(.hero-kicker) {
      max-width: 300px;
    }

    .hero-actions {
      width: 100%;
      flex-direction: column;
      align-items: stretch;
    }

    .home-content {
      padding-top: 34px;
    }

    .category-section,
    .featured-section,
    .feed-section {
      margin-bottom: 38px;
    }

    .featured-story {
      min-height: 0;
      grid-template-columns: 58px minmax(0, 1fr);
    }

    .featured-number {
      font-size: 1.25rem;
    }

    .featured-copy {
      padding: 24px 20px;
    }

    .featured-copy h3 {
      font-size: 1.25rem;
    }

    .story-arrow {
      display: none;
    }

    .content-grid {
      grid-template-columns: 1fr;
    }

    .content-card {
      min-height: 214px;
    }

    .archive-band {
      grid-template-columns: 42px minmax(0, 1fr);
      gap: 14px;
      padding: 20px;
    }

    .archive-band-icon {
      width: 42px;
      height: 42px;
    }

    .archive-button {
      grid-column: 1 / -1;
      width: 100%;
    }
  }
</style>
