---
export const prerender = false;

import { env } from "cloudflare:workers";
import { CalendarDays, Check, Clock3, History, Sparkles } from "lucide-astro";
import Base from "../layouts/Base.astro";
import { FALLBACK_RELEASE_FEED, isReleaseFeed, type ReleaseFeed } from "../lib/releases";

let feed: ReleaseFeed = FALLBACK_RELEASE_FEED;
try {
  const response = await env.INGEST.fetch("https://life-quiz-ingest/internal/releases", {
    headers: { "x-life-quiz-service": "releases" },
  });
  if (response.ok) {
    const value: unknown = await response.json();
    if (isReleaseFeed(value)) feed = value;
  }
} catch {
  // The checked-in snapshot keeps this public page useful during an upstream outage.
}

// Cached at the edge: release notes only change when a new version ships,
// so short-lived edge caching avoids re-fetching the ingest worker on every visit.
Astro.response.headers.set("cache-control", "public, max-age=90, stale-while-revalidate=600");

const latest = feed.releases[0];

function displayDate(value: string | null) {
  if (!value) return "날짜 미정";
  return new Intl.DateTimeFormat("ko-KR", {
    year: "numeric",
    month: "long",
    day: "numeric",
    timeZone: "Asia/Seoul",
  }).format(new Date(`${value}T00:00:00+09:00`));
}
---

<Base title="릴리즈 노트" description="라이프퀴즈의 새로운 기능과 개선 내역을 버전별로 확인합니다.">
  <div class="release-page shell">
    <header class="release-header">
      <div>
        <p class="eyebrow"><History size={15} /> PRODUCT UPDATES</p>
        <h1 class="page-title">릴리즈 노트</h1>
        <p>라이프퀴즈가 조금씩 더 쓸모 있어지는 과정을 기록합니다.</p>
      </div>
      {latest && (
        <div class="latest-mark" aria-label={`최신 버전 ${latest.version}`}>
          <Sparkles size={17} />
          <span>최신 버전</span>
          <strong>{latest.version}</strong>
        </div>
      )}
    </header>

    <section class="release-summary" aria-label="릴리즈 요약">
      <div>
        <span>누적 릴리즈</span>
        <strong>{feed.releases.length}</strong>
      </div>
      <div>
        <span>최근 업데이트</span>
        <strong>{displayDate(latest?.date ?? null)}</strong>
      </div>
      <p><Clock3 size={15} /> 새 기록은 최대 5분 안에 반영됩니다.</p>
    </section>

    {feed.releases.length > 0 ? (
      <div class="release-layout">
        <nav class="release-nav" aria-label="버전 바로가기">
          {feed.releases.map((release, index) => (
            <a href={`#v-${release.version}`} class:list={{ latest: index === 0 }}>
              <span class="version-label">{release.version}</span>
              <small>{displayDate(release.date)}</small>
            </a>
          ))}
        </nav>

        <ol class="release-list" aria-label="버전별 업데이트 내역">
          {feed.releases.map((release, index) => (
            <li id={`v-${release.version}`} class:list={["release-item", { latest: index === 0 }]}>
              <span class="timeline-dot" aria-hidden="true"></span>
              <article class="release-card">
                <header class="release-card-header">
                  <div class="version-line">
                    <span class="version-label">{release.version}</span>
                    {index === 0 && <span class="new-label">NEW</span>}
                  </div>
                  <h2>{release.title}</h2>
                  <time datetime={release.date ?? undefined}><CalendarDays size={15} /> {displayDate(release.date)}</time>
                </header>

                <ul class="change-list">
                  {release.changes.map((change, changeIndex) => (
                    <li class:list={[`change-${change.type}`, { "new-section": change.section && change.section !== release.changes[changeIndex - 1]?.section }]}>
                      {change.section && change.section !== release.changes[changeIndex - 1]?.section && <strong>{change.section}</strong>}
                      <span><Check size={15} /> {change.text}</span>
                    </li>
                  ))}
                </ul>
              </article>
            </li>
          ))}
        </ol>
      </div>
    ) : (
      <section class="release-empty">
        <History size={30} />
        <h2>아직 공개된 릴리즈가 없습니다</h2>
      </section>
    )}
  </div>
</Base>

<style>
  .release-page {
    padding-top: 54px;
  }

  .release-header {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 36px;
    padding-bottom: 28px;
  }

  .release-header .eyebrow {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .release-header > div:first-child > p:last-child {
    max-width: 580px;
    margin: 13px 0 0;
    color: var(--muted-strong);
  }

  .latest-mark {
    min-width: 150px;
    display: grid;
    grid-template-columns: 20px 1fr;
    align-items: center;
    gap: 1px 8px;
    padding: 12px 14px;
    border-left: 3px solid var(--green);
    color: var(--green-deep);
    background: var(--green-soft);
  }

  .latest-mark svg {
    grid-row: 1 / 3;
  }

  .latest-mark span {
    font-size: 0.68rem;
    font-weight: 750;
  }

  .latest-mark strong {
    font-size: 1.02rem;
  }

  .release-summary {
    display: grid;
    grid-template-columns: 150px 240px minmax(0, 1fr);
    align-items: center;
    gap: 24px;
    margin-bottom: 42px;
    padding: 20px 0;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }

  .release-summary > div {
    display: grid;
    gap: 2px;
  }

  .release-summary span,
  .release-summary p {
    color: var(--muted);
    font-size: 0.76rem;
    font-weight: 700;
  }

  .release-summary strong {
    color: var(--ink);
    font-size: 1.05rem;
  }

  .release-summary p {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 6px;
    margin: 0;
  }

  .release-layout {
    display: grid;
    grid-template-columns: 210px minmax(0, 1fr);
    align-items: start;
    gap: 24px;
  }

  .release-nav {
    position: sticky;
    top: 88px;
    max-height: calc(100vh - 110px);
    display: grid;
    gap: 2px;
    overflow-y: auto;
    padding: 6px;
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    background: var(--paper);
    scrollbar-width: thin;
  }

  .release-nav a {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    padding: 9px 10px;
    border-radius: var(--radius-sm);
    color: var(--muted-strong);
    text-decoration: none;
  }

  .release-nav a:hover {
    background: var(--surface-strong);
  }

  .release-nav a.latest {
    color: var(--green-deep);
  }

  .release-nav .version-label {
    font-size: 0.82rem;
    font-weight: 800;
  }

  .release-nav small {
    color: var(--muted);
    font-size: 0.68rem;
    white-space: nowrap;
  }

  .release-list {
    position: relative;
    display: grid;
    gap: 20px;
    min-width: 0;
    padding: 0 0 10px 34px;
    list-style: none;
  }

  .release-list::before {
    position: absolute;
    top: 8px;
    bottom: 0;
    left: 8px;
    width: 2px;
    background: var(--line);
    content: "";
  }

  .release-item {
    position: relative;
    --release-color: var(--green);
    --release-soft: var(--green-soft);
  }

  .release-item:nth-child(4n + 2) { --release-color: var(--berry); --release-soft: var(--berry-soft); }
  .release-item:nth-child(4n + 3) { --release-color: var(--blue); --release-soft: var(--blue-soft); }
  .release-item:nth-child(4n) { --release-color: var(--coral); --release-soft: var(--coral-soft); }

  .timeline-dot {
    position: absolute;
    top: 25px;
    left: -32px;
    width: 14px;
    height: 14px;
    border: 3px solid var(--canvas);
    border-radius: 50%;
    background: var(--release-color);
    box-shadow: 0 0 0 1px var(--release-color);
  }

  .release-card {
    display: grid;
    grid-template-columns: minmax(170px, 0.34fr) minmax(0, 1fr);
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    background: var(--paper);
    box-shadow: var(--shadow-sm);
  }

  .release-card-header {
    padding: 24px;
    border-right: 1px solid var(--line);
    background: var(--release-soft);
  }

  .version-line {
    display: flex;
    align-items: center;
    gap: 7px;
  }

  .version-label {
    color: var(--release-color);
    font-size: 1.1rem;
    font-weight: 850;
  }

  .new-label {
    padding: 3px 5px;
    border-radius: 3px;
    color: white;
    background: var(--release-color);
    font-size: 0.58rem;
    font-weight: 850;
  }

  .release-card h2 {
    margin: 10px 0 15px;
    font-size: 1.1rem;
    line-height: 1.35;
  }

  .release-card time {
    display: flex;
    align-items: center;
    gap: 5px;
    color: var(--muted-strong);
    font-size: 0.74rem;
    font-weight: 650;
  }

  .change-list {
    display: grid;
    align-content: center;
    gap: 11px;
    margin: 0;
    padding: 24px 26px;
    list-style: none;
  }

  .change-list li {
    display: grid;
    gap: 7px;
  }

  .change-list li > strong {
    color: var(--release-color);
    font-size: 0.72rem;
  }

  .change-list li > span {
    display: grid;
    grid-template-columns: 17px minmax(0, 1fr);
    gap: 7px;
    color: var(--muted-strong);
    font-size: 0.87rem;
    line-height: 1.55;
  }

  .change-list svg {
    margin-top: 3px;
    color: var(--release-color);
  }

  .change-callout > span {
    padding: 9px 10px;
    border-left: 2px solid var(--release-color);
    background: var(--release-soft);
  }

  .release-empty {
    display: grid;
    justify-items: center;
    gap: 10px;
    padding: 70px 20px;
    color: var(--muted);
  }

  .release-empty h2 {
    margin: 0;
    color: var(--ink);
    font-size: 1.1rem;
  }

  @media (max-width: 900px) {
    .release-layout {
      grid-template-columns: 1fr;
    }

    .release-nav {
      position: static;
      max-height: none;
      grid-auto-flow: column;
      grid-auto-columns: minmax(120px, auto);
      overflow-x: auto;
    }

    .release-list {
      padding-left: 26px;
    }
  }

  @media (max-width: 760px) {
    .release-page {
      padding-top: 34px;
    }

    .release-header {
      align-items: start;
    }

    .latest-mark {
      min-width: 118px;
    }

    .release-summary {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 16px;
    }

    .release-summary p {
      grid-column: 1 / -1;
      justify-content: flex-start;
    }

    .release-card {
      grid-template-columns: 1fr;
    }

    .release-card-header {
      border-right: 0;
      border-bottom: 1px solid var(--line);
    }
  }

  @media (max-width: 520px) {
    .release-header {
      display: grid;
    }

    .latest-mark {
      width: 100%;
      grid-template-columns: 20px auto 1fr;
      border-left: 0;
      border-bottom: 3px solid var(--green);
    }

    .latest-mark svg {
      grid-row: auto;
    }

    .latest-mark strong {
      justify-self: end;
    }

    .release-list {
      padding-left: 25px;
    }

    .release-list::before {
      left: 4px;
    }

    .timeline-dot {
      left: -27px;
    }

    .release-card-header,
    .change-list {
      padding: 20px;
    }
  }
</style>
