---
// This page has no server-side data dependency (the queue loads client-side
// from /api/reviews/due), so it's statically prerendered instead of paying
// for an SSR + D1 round trip on every visit.
export const prerender = true;

import { Brain, CalendarClock, CheckCircle2, RotateCcw } from "lucide-astro";
import Base from "../layouts/Base.astro";
---

<Base title="오늘의 복습" description="FSRS 간격 반복으로 오늘 기억해야 할 생활 상식을 복습합니다.">
  <div class="review-page shell">
    <header class="review-header">
      <div>
        <p class="eyebrow">SPACED REPETITION</p>
        <h1 class="page-title">오늘의 복습</h1>
        <p>정답을 고르면 FSRS가 다음에 다시 만날 날짜를 정해요.</p>
      </div>
      <div class="review-header-icon" aria-hidden="true"><Brain size={32} strokeWidth={1.8} /></div>
    </header>

    <div class="review-layout">
      <aside class="review-guide" aria-label="복습 안내">
        <div class="guide-item">
          <span><RotateCcw size={18} /></span>
          <div><strong>기억을 꺼내보기</strong><p>답을 보기 전 잠깐 떠올려 보세요.</p></div>
        </div>
        <div class="guide-item">
          <span><CalendarClock size={18} /></span>
          <div><strong>알맞은 때 다시 보기</strong><p>기억 상태에 따라 다음 날짜가 달라져요.</p></div>
        </div>
        <div class="guide-item">
          <span><CheckCircle2 size={18} /></span>
          <div><strong>오늘 분량만 가볍게</strong><p>한 번에 오래 하기보다 꾸준함이 중요해요.</p></div>
        </div>
      </aside>

      <section class="review-workspace" aria-live="polite">
        <div id="review-root">
          <div class="loading-state" role="status">
            <span class="loading-spinner" aria-hidden="true"></span>
            <p>오늘의 카드를 불러오고 있어요</p>
          </div>
        </div>
      </section>
    </div>
  </div>
</Base>

<style is:global>
  .review-page {
    padding-top: 54px;
  }

  .review-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 30px;
    margin-bottom: 38px;
  }

  .review-header > div > p:not(.eyebrow) {
    margin: 10px 0 0;
    color: var(--muted);
  }

  .review-header-icon {
    width: 66px;
    height: 66px;
    display: grid;
    place-items: center;
    flex: 0 0 66px;
    border-radius: var(--radius-md);
    color: var(--green-deep);
    background: var(--green-soft);
  }

  .review-layout {
    display: grid;
    grid-template-columns: 250px minmax(0, 1fr);
    align-items: start;
    gap: 20px;
  }

  .review-guide {
    padding: 22px;
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    background: var(--paper);
  }

  .guide-item {
    display: grid;
    grid-template-columns: 32px minmax(0, 1fr);
    gap: 10px;
    padding: 16px 0;
    border-bottom: 1px solid var(--line);
  }

  .guide-item:first-child { padding-top: 0; }
  .guide-item:last-child { padding-bottom: 0; border-bottom: 0; }

  .guide-item > span {
    width: 32px;
    height: 32px;
    display: grid;
    place-items: center;
    border-radius: var(--radius-sm);
    color: var(--green);
    background: var(--green-soft);
  }

  .guide-item strong {
    font-size: 0.83rem;
  }

  .guide-item p {
    margin: 3px 0 0;
    color: var(--muted);
    font-size: 0.73rem;
    line-height: 1.5;
  }

  .review-workspace {
    min-width: 0;
  }

  .loading-state,
  .empty-review,
  .error-state {
    min-height: 420px;
    display: grid;
    place-content: center;
    justify-items: center;
    padding: 36px;
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    background: var(--paper);
    text-align: center;
  }

  .loading-state p,
  .empty-review p,
  .error-state p {
    margin: 12px 0 0;
    color: var(--muted);
  }

  .loading-spinner {
    width: 28px;
    height: 28px;
    border: 3px solid var(--line);
    border-top-color: var(--green);
    border-radius: 50%;
    animation: spin 800ms linear infinite;
  }

  @keyframes spin { to { transform: rotate(360deg); } }

  .review-progress {
    margin-bottom: 12px;
  }

  .progress-copy {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 8px;
    color: var(--muted);
    font-size: 0.78rem;
    font-weight: 700;
  }

  .progress-track {
    height: 7px;
    overflow: hidden;
    border-radius: 4px;
    background: var(--surface-strong);
  }

  .progress-value {
    height: 100%;
    border-radius: 4px;
    background: var(--green);
    transition: width 220ms ease;
  }

  .quiz-card {
    min-height: 430px;
    display: flex;
    flex-direction: column;
    padding: 30px;
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    background: var(--paper);
    box-shadow: var(--shadow-sm);
  }

  .quiz-source {
    display: flex;
    align-items: center;
    gap: 8px;
    margin: 0 0 22px;
    color: var(--muted);
    font-size: 0.76rem;
  }

  .quiz-source span:first-child {
    max-width: 75%;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .quiz-card h2 {
    max-width: 800px;
    margin: 0 0 28px;
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    line-height: 1.45;
    word-break: keep-all;
  }

  .choices {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
  }

  .choice {
    min-height: 66px;
    display: grid;
    grid-template-columns: 30px minmax(0, 1fr);
    align-items: center;
    gap: 11px;
    padding: 10px 14px;
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    background: var(--surface);
    cursor: pointer;
    text-align: left;
    transition: border-color 140ms ease, background-color 140ms ease;
  }

  .choice:hover:not(:disabled) {
    border-color: var(--green);
    background: var(--green-soft);
  }

  .choice:disabled {
    cursor: default;
  }

  .choice-letter {
    width: 30px;
    height: 30px;
    display: grid;
    place-items: center;
    border-radius: var(--radius-sm);
    color: var(--muted-strong);
    background: var(--surface-strong);
    font-size: 0.76rem;
    font-weight: 850;
  }

  .choice-text {
    min-width: 0;
    font-size: 0.9rem;
    line-height: 1.4;
  }

  .choice.correct {
    border-color: var(--green);
    background: var(--green-soft);
  }

  .choice.correct .choice-letter {
    color: white;
    background: var(--green);
  }

  .choice.incorrect {
    border-color: var(--coral);
    background: var(--coral-soft);
  }

  .choice.incorrect .choice-letter {
    color: white;
    background: var(--coral);
  }

  .answer-feedback {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    margin-top: 24px;
    padding-top: 22px;
    border-top: 1px solid var(--line);
  }

  .feedback-copy strong {
    display: block;
    margin-bottom: 4px;
    font-size: 0.96rem;
  }

  .feedback-copy p {
    margin: 0;
    color: var(--muted);
    font-size: 0.8rem;
  }

  .feedback-copy .feedback-explanation {
    max-width: 680px;
    margin: 7px 0 9px;
    color: var(--muted-strong);
    font-size: 0.86rem;
    line-height: 1.6;
  }

  .feedback-due {
    font-weight: 700;
  }

  .next-button {
    min-width: 114px;
  }

  .empty-review h2,
  .error-state h2 {
    margin: 14px 0 0;
    font-size: 1.3rem;
  }

  .empty-actions {
    display: flex;
    gap: 8px;
    margin-top: 22px;
  }

  @media (max-width: 820px) {
    .review-layout {
      grid-template-columns: 1fr;
    }

    .review-guide {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 12px;
      padding: 14px;
    }

    .guide-item {
      display: block;
      padding: 0;
      border: 0;
    }

    .guide-item > span {
      margin-bottom: 8px;
    }
  }

  @media (max-width: 600px) {
    .review-page {
      padding-top: 34px;
    }

    .review-header {
      margin-bottom: 26px;
    }

    .review-header-icon {
      width: 52px;
      height: 52px;
      flex-basis: 52px;
    }

    .review-header > div > p:not(.eyebrow) {
      font-size: 0.84rem;
    }

    .review-guide {
      grid-template-columns: 1fr;
    }

    .guide-item {
      display: grid;
      grid-template-columns: 32px minmax(0, 1fr);
    }

    .quiz-card {
      min-height: 0;
      padding: 22px 18px;
    }

    .choices {
      grid-template-columns: 1fr;
    }

    .answer-feedback {
      align-items: stretch;
      flex-direction: column;
    }

    .next-button {
      width: 100%;
    }
  }
</style>

<script>
  import { getAnonymousUserId } from "../lib/anonymous-user";
  import { element } from "../lib/dom";

  interface DueCard {
    quizItemId: number;
    title: string;
    category: string;
    citationLabel: string;
    question: string;
    choices: string[];
    isNew: boolean;
  }

  interface SubmitResult {
    isCorrect: boolean | null;
    correctAnswer?: string;
    explanation?: string;
    due: string;
  }

  const root = document.querySelector<HTMLElement>("#review-root");
  const reviewUserId = getAnonymousUserId();
  let queue: DueCard[] = [];
  let currentIndex = 0;

  function element<K extends keyof HTMLElementTagNameMap>(tag: K, className?: string, text?: string) {
    const node = document.createElement(tag);
    if (className) node.className = className;
    if (text !== undefined) node.textContent = text;
    return node;
  }

  function appendButtonLink(parent: HTMLElement, href: string, label: string, primary = false) {
    const link = element("a", `button ${primary ? "button-primary" : "button-secondary"}`, label);
    link.href = href;
    parent.append(link);
  }

  async function initializeReview() {
    if (!root) return;

    try {
      const response = await fetch(`/api/reviews/due?userId=${encodeURIComponent(reviewUserId)}`, { headers: { accept: "application/json" } });
      if (!response.ok) throw new Error("복습 카드를 불러오지 못했습니다.");
      const data = (await response.json()) as { cards?: DueCard[] };
      queue = Array.isArray(data.cards) ? data.cards : [];
      currentIndex = 0;
      renderCurrentCard();
    } catch (error) {
      renderError(error instanceof Error ? error.message : "잠시 후 다시 시도해주세요.");
    }
  }

  function renderError(message: string) {
    if (!root) return;
    root.replaceChildren();
    const state = element("div", "error-state");
    state.append(element("h2", "", "복습을 불러오지 못했어요"), element("p", "", message));
    const retry = element("button", "button button-primary", "다시 시도");
    retry.type = "button";
    retry.addEventListener("click", initializeReview);
    state.append(retry);
    root.append(state);
  }

  function renderComplete() {
    if (!root) return;
    root.replaceChildren();
    const state = element("div", "empty-review");
    state.append(element("h2", "", queue.length === 0 ? "복습에 담긴 카드가 없어요" : "오늘의 복습을 마쳤어요"));
    state.append(element("p", "", queue.length === 0 ? "관심 있는 글에서 '복습에 담기'를 누르면 그 글의 퀴즈만 준비됩니다." : `${queue.length}개의 기억을 다시 단단하게 만들었습니다.`));
    const actions = element("div", "empty-actions");
    appendButtonLink(actions, "/start", "시작 코스 고르기", true);
    appendButtonLink(actions, "/", "새 상식 읽기");
    state.append(actions);
    root.append(state);
  }

  function renderCurrentCard() {
    if (!root) return;
    if (currentIndex >= queue.length) {
      renderComplete();
      return;
    }

    const card = queue[currentIndex];
    root.replaceChildren();

    const progress = element("div", "review-progress");
    const progressCopy = element("div", "progress-copy");
    progressCopy.append(element("span", "", `카드 ${currentIndex + 1} / ${queue.length}`), element("span", "", card.isNew ? "새 카드" : "복습 카드"));
    const track = element("div", "progress-track");
    const value = element("div", "progress-value");
    value.style.width = `${((currentIndex + 1) / queue.length) * 100}%`;
    track.append(value);
    progress.append(progressCopy, track);

    const quizCard = element("div", "quiz-card");
    const source = element("p", "quiz-source");
    source.append(element("span", "", card.title), element("span", "", `· ${card.citationLabel}`));
    quizCard.append(source, element("h2", "", card.question));

    const choices = element("div", "choices");
    card.choices.forEach((choice, index) => {
      const button = element("button", "choice");
      button.type = "button";
      button.dataset.choice = choice;
      button.append(element("span", "choice-letter", String.fromCharCode(65 + index)), element("span", "choice-text", choice));
      button.addEventListener("click", () => submitAnswer(card, button, choices));
      choices.append(button);
    });
    quizCard.append(choices);
    root.append(progress, quizCard);
  }

  async function submitAnswer(card: DueCard, selected: HTMLButtonElement, choices: HTMLElement) {
    const buttons = Array.from(choices.querySelectorAll<HTMLButtonElement>(".choice"));
    buttons.forEach((button) => { button.disabled = true; });

    try {
      const response = await fetch(`/api/reviews/${card.quizItemId}`, {
        method: "POST",
        headers: { "content-type": "application/json", accept: "application/json" },
        body: JSON.stringify({ answer: selected.dataset.choice, userId: reviewUserId }),
      });
      if (!response.ok) throw new Error("답안을 저장하지 못했습니다.");
      const result = (await response.json()) as SubmitResult;

      buttons.forEach((button) => {
        if (button.dataset.choice === selected.dataset.choice) button.classList.add(result.isCorrect ? "correct" : "incorrect");
        if (result.correctAnswer && button.dataset.choice === result.correctAnswer) button.classList.add("correct");
      });

      const feedback = element("div", "answer-feedback");
      const copy = element("div", "feedback-copy");
      copy.append(element("strong", "", result.isCorrect ? "정답이에요" : `정답은 '${result.correctAnswer}'예요`));
      if (result.explanation) {
        copy.append(element("p", "feedback-explanation", result.explanation));
      }
      const dueDate = new Intl.DateTimeFormat("ko-KR", { year: "numeric", month: "long", day: "numeric" }).format(new Date(result.due));
      copy.append(element("p", "feedback-due", `다음 복습 예정일: ${dueDate}`));
      const next = element("button", "button button-primary next-button", currentIndex + 1 === queue.length ? "복습 마치기" : "다음 카드");
      next.type = "button";
      next.addEventListener("click", () => { currentIndex += 1; renderCurrentCard(); });
      feedback.append(copy, next);
      choices.parentElement?.append(feedback);
    } catch (error) {
      buttons.forEach((button) => { button.disabled = false; });
      renderError(error instanceof Error ? error.message : "잠시 후 다시 시도해주세요.");
    }
  }

  void initializeReview();
</script>
