---
export const prerender = false;

import { env } from "cloudflare:workers";
import { ArrowLeft, BookmarkPlus, CheckCircle2, ChevronLeft, ChevronRight, ExternalLink, MessageCircle, PanelsTopLeft, ShieldAlert } from "lucide-astro";
import Base from "../../layouts/Base.astro";
import VisualCue from "../../components/VisualCue.astro";
import { createDb } from "../../db/client";
import { getContentItemWithQuiz } from "../../lib/content";
import { categoryLabel } from "../../lib/categories";
import { formatLongDate } from "../../lib/dates";

const id = Number(Astro.params.id);
const db = createDb(env.DB);
const result = Number.isInteger(id) ? await getContentItemWithQuiz(db, id) : null;

if (!result) {
  return Astro.redirect("/");
}

const { item, quizzes } = result;
const isVisualGuide = item.contentFormat === "visual_guide";
const paragraphs = item.bodyMd.split(/\n{2,}/).map((paragraph) => paragraph.trim()).filter(Boolean);
const deepReadSections = paragraphs.map((body, index) => ({
  heading: item.cards?.[index]?.heading ?? `핵심 ${index + 1}`,
  body,
}));
const actionCard = item.cards?.at(-1) ?? null;
const publishedAt = formatLongDate(item.createdAt);

// Cached at the edge: published articles are immutable once created.
Astro.response.headers.set("cache-control", "public, max-age=300, stale-while-revalidate=1800");
---

<Base title={item.title} description={`${item.title} - ${item.citationLabel}`}>
  <article class="article-shell shell" data-category={item.category}>
    <a class="back-link" href="/"><ArrowLeft size={17} /> 상식 피드로</a>

    <header class="article-header">
      <span class="category-label" data-category={item.category}>{categoryLabel(item.category)}</span>
      <h1>{item.title}</h1>
      <div class="article-meta">
        <span>{publishedAt}</span>
        <span aria-hidden="true">·</span>
        <span>{item.citationLabel}</span>
      </div>
      {item.category === "investment" && (
        <p class="investment-caution"><ShieldAlert size={16} /> 학습을 위한 일반 정보이며 특정 종목이나 상품의 투자 권유가 아닙니다.</p>
      )}
    </header>

    {isVisualGuide && item.cards && item.cards.length > 0 && (
      <section class="visual-guide-section" aria-labelledby="visual-guide-title">
        <div class="card-news-toolbar">
          <div>
            <p class="eyebrow">VISUAL GLOSSARY</p>
            <h2 id="visual-guide-title"><PanelsTopLeft size={20} /> 4컷으로 용어 이해하기</h2>
          </div>
          <span class="visual-guide-count">1분 개념 정리</span>
        </div>

        <ol class="comic-grid">
          {item.cards.map((card, index) => (
            <li class="comic-panel">
              <div class="comic-visual">
                <span>{index + 1} / {item.cards!.length}</span>
                <VisualCue cue={card.visual} size={54} />
              </div>
              <div class="comic-speech">
                <h3>{card.heading}</h3>
                <p>{card.body}</p>
              </div>
            </li>
          ))}
        </ol>
      </section>
    )}

    {!isVisualGuide && item.cards && item.cards.length > 0 && (
      <section class="card-news-section" aria-labelledby="card-news-title">
        <div class="card-news-toolbar">
          <div>
            <p class="eyebrow">QUICK READ</p>
            <h2 id="card-news-title">카드로 먼저 훑어보기</h2>
          </div>
          <div class="carousel-controls">
            <span class="carousel-count" aria-live="polite"><strong id="current-slide">1</strong> / {item.cards.length}</span>
            <button class="icon-button" id="previous-card" type="button" aria-label="이전 카드">
              <ChevronLeft size={20} />
            </button>
            <button class="icon-button" id="next-card" type="button" aria-label="다음 카드">
              <ChevronRight size={20} />
            </button>
          </div>
        </div>

        <div class="card-news-track" id="card-news-track" tabindex="0" aria-label="카드뉴스">
          {item.cards.map((card, index) => (
            <section class="card-news" data-slide-index={index} aria-label={`${index + 1}번째 카드`}>
              <span class="card-index">{String(index + 1).padStart(2, "0")}</span>
              <div>
                <h3>{card.heading}</h3>
                <p>{card.body}</p>
              </div>
              <span class="card-brand">LIFE QUIZ</span>
            </section>
          ))}
        </div>
        <div class="slide-dots" aria-label="카드 선택">
          {item.cards.map((_, index) => (
            <button
              type="button"
              class:list={["slide-dot", { active: index === 0 }]}
              data-slide-target={index}
              aria-label={`${index + 1}번째 카드 보기`}
              aria-current={index === 0 ? "true" : undefined}
            ></button>
          ))}
        </div>
      </section>
    )}

    <div class="article-grid">
      <div class="article-main">
        <section class="article-body" aria-labelledby="article-body-title">
          <p class="eyebrow">DEEP READ</p>
          <h2 id="article-body-title">카드에서 본 내용을 더 깊게</h2>
          <div class="deep-read-list">
            {deepReadSections.map((section, index) => (
              <section class="deep-read-section">
                <span aria-hidden="true">{String(index + 1).padStart(2, "0")}</span>
                <div>
                  <h3>{section.heading}</h3>
                  <p>{section.body}</p>
                </div>
              </section>
            ))}
          </div>
        </section>

        {actionCard && (
          <section class="action-takeaway" aria-labelledby="action-takeaway-title">
            <span class="action-icon" aria-hidden="true"><CheckCircle2 size={22} /></span>
            <div>
              <p class="eyebrow">DO THIS NEXT</p>
              <h2 id="action-takeaway-title">오늘 바로 확인할 것</h2>
              <p><strong>{actionCard.heading}</strong> {actionCard.body}</p>
            </div>
          </section>
        )}

        <section class="source-note" aria-labelledby="source-title">
          <div>
            <p class="eyebrow">SOURCE</p>
            <h2 id="source-title">어디에서 온 정보인가요?</h2>
            <p>핵심 내용을 이해하기 쉽게 재구성했습니다. 중요한 결정 전에는 원문을 함께 확인하세요.</p>
          </div>
          {item.citationUrl ? (
            <a class="button button-secondary" href={item.citationUrl} target="_blank" rel="noopener noreferrer">
              {item.citationLabel} <ExternalLink size={16} />
            </a>
          ) : (
            <span class="ai-source">{item.citationLabel}</span>
          )}
        </section>
      </div>

      <aside class="article-actions" aria-label="이 글로 다음에 할 일">
        <p class="eyebrow">NEXT STEP</p>
        <h2>읽은 내용을<br />내 것으로 만들기</h2>
        <p>헷갈리는 부분은 바로 묻고, 퀴즈로 다시 만나보세요.</p>
        <a class="action-link chat" href={`/chat?content=${item.id}`}>
          <MessageCircle size={19} />
          <span><strong>이 글에 대해 질문하기</strong><small>라이프 메이트가 맥락을 이어받아요</small></span>
          <ChevronRight size={18} />
        </a>
        {quizzes.length > 0 && (
          <button class="action-link review" id="learning-button" type="button" data-content-id={item.id} disabled>
            <BookmarkPlus size={19} />
            <span><strong id="learning-label">복습에 담기</strong><small id="learning-description">이 글의 퀴즈만 내 복습에 추가해요</small></span>
            <ChevronRight size={18} />
          </button>
        )}
        <p class="learning-status" id="learning-status" aria-live="polite"></p>
      </aside>
    </div>
  </article>
</Base>

<style>
  .article-shell {
    /* --category-color / --category-soft come from the global [data-category] map. */
    --article-color: var(--category-color, var(--green));
    --article-soft: var(--category-soft, var(--green-soft));
    padding-top: 30px;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--muted-strong);
    text-decoration: none;
    font-size: 0.84rem;
    font-weight: 700;
  }

  .article-header {
    max-width: 860px;
    margin: 58px auto 48px;
    text-align: center;
  }

  .article-header h1 {
    margin: 14px 0 18px;
    font-size: clamp(2rem, 5vw, 3.8rem);
    line-height: 1.16;
    word-break: keep-all;
  }

  .article-meta {
    display: flex;
    justify-content: center;
    gap: 7px;
    color: var(--muted);
    font-size: 0.82rem;
  }

  .investment-caution {
    max-width: 620px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 7px;
    margin: 18px auto 0;
    padding: 10px 12px;
    border: 1px solid color-mix(in srgb, var(--berry) 28%, var(--line));
    border-radius: var(--radius-md);
    color: #71304d;
    background: var(--berry-soft);
    font-size: 0.76rem;
    font-weight: 700;
  }

  .card-news-section {
    margin-bottom: 64px;
  }

  .visual-guide-section {
    margin-bottom: 64px;
  }

  .visual-guide-section .card-news-toolbar h2 {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .visual-guide-count {
    padding: 7px 10px;
    border: 1px solid color-mix(in srgb, var(--article-color) 25%, var(--line));
    border-radius: var(--radius-sm);
    color: var(--article-color);
    background: var(--article-soft);
    font-size: 0.76rem;
    font-weight: 800;
  }

  .comic-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .comic-panel {
    min-height: 300px;
    display: grid;
    grid-template-columns: minmax(130px, 0.42fr) minmax(0, 1fr);
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--article-color) 24%, var(--line));
    border-radius: var(--radius-md);
    background: var(--paper);
    box-shadow: var(--shadow-sm);
  }

  .comic-visual {
    display: grid;
    place-items: center;
    align-content: space-between;
    padding: 22px 18px 38px;
    color: var(--article-color);
    background: var(--article-soft);
  }

  .comic-visual span {
    justify-self: start;
    font-size: 0.7rem;
    font-weight: 850;
  }

  .comic-visual :global(svg) {
    filter: drop-shadow(0 8px 16px color-mix(in srgb, var(--article-color) 18%, transparent));
  }

  .comic-speech {
    align-self: center;
    position: relative;
    margin: 24px;
    padding: 20px;
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    background: var(--surface);
  }

  .comic-speech::before {
    position: absolute;
    top: 42%;
    left: -9px;
    width: 16px;
    height: 16px;
    transform: rotate(45deg);
    border-bottom: 1px solid var(--line);
    border-left: 1px solid var(--line);
    background: var(--surface);
    content: "";
  }

  .comic-speech h3 {
    margin: 0 0 9px;
    font-size: 1.15rem;
    line-height: 1.35;
  }

  .comic-speech p {
    margin: 0;
    color: var(--muted-strong);
    font-size: 0.88rem;
    line-height: 1.7;
  }

  .card-news-toolbar {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 20px;
    margin-bottom: 16px;
  }

  .card-news-toolbar h2 {
    margin: 0;
    font-size: 1.28rem;
  }

  .carousel-controls {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .carousel-count {
    min-width: 54px;
    color: var(--muted);
    font-size: 0.82rem;
    text-align: center;
  }

  .carousel-count strong {
    color: var(--ink);
  }

  .card-news-track {
    display: flex;
    gap: 14px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
  }

  .card-news-track::-webkit-scrollbar {
    display: none;
  }

  .card-news {
    aspect-ratio: 1 / 0.62;
    min-height: 300px;
    flex: 0 0 calc(50% - 7px);
    display: grid;
    grid-template-rows: auto 1fr auto;
    scroll-snap-align: start;
    padding: 28px;
    border: 1px solid color-mix(in srgb, var(--article-color) 24%, var(--line));
    border-radius: var(--radius-md);
    background: var(--article-soft);
  }

  .card-news:nth-child(even) {
    background: var(--ink);
    color: white;
  }

  .card-index,
  .card-brand {
    color: var(--article-color);
    font-size: 0.72rem;
    font-weight: 850;
  }

  .card-news:nth-child(even) .card-index,
  .card-news:nth-child(even) .card-brand {
    color: #a8d7c4;
  }

  .card-news > div {
    align-self: center;
  }

  .card-news h3 {
    margin: 0 0 13px;
    font-size: clamp(1.35rem, 2.5vw, 2rem);
    line-height: 1.25;
  }

  .card-news p {
    margin: 0;
    color: var(--muted-strong);
    font-size: 0.96rem;
    line-height: 1.7;
  }

  .card-news:nth-child(even) p {
    color: #d5ddd9;
  }

  .slide-dots {
    display: flex;
    justify-content: center;
    gap: 7px;
    margin-top: 16px;
  }

  .slide-dot {
    width: 22px;
    height: 5px;
    padding: 0;
    border-radius: 3px;
    background: var(--line);
    cursor: pointer;
  }

  .slide-dot.active {
    background: var(--article-color);
  }

  .article-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 320px;
    align-items: start;
    gap: 44px;
  }

  .article-main {
    min-width: 0;
  }

  .article-body {
    padding: 34px 38px;
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    background: var(--paper);
    box-shadow: var(--shadow-sm);
  }

  .article-body > h2 {
    margin: 2px 0 26px;
    font-size: 1.3rem;
  }

  .deep-read-list {
    display: grid;
  }

  .deep-read-section {
    display: grid;
    grid-template-columns: 34px minmax(0, 1fr);
    gap: 14px;
    padding: 22px 0;
    border-top: 1px solid var(--line);
  }

  .deep-read-section > span {
    padding-top: 3px;
    color: var(--article-color);
    font-size: 0.72rem;
    font-weight: 850;
  }

  .deep-read-section h3 {
    margin: 0 0 8px;
    font-size: 1.04rem;
  }

  .deep-read-section p {
    margin: 0;
    color: #2f3b35;
    font-size: 1rem;
    line-height: 1.9;
    word-break: keep-all;
  }

  .action-takeaway {
    display: grid;
    grid-template-columns: 44px minmax(0, 1fr);
    gap: 16px;
    margin-top: 18px;
    padding: 22px 24px;
    border: 1px solid color-mix(in srgb, var(--article-color) 30%, var(--line));
    border-radius: var(--radius-md);
    background: var(--article-soft);
  }

  .action-icon {
    width: 44px;
    height: 44px;
    display: grid;
    place-items: center;
    border-radius: var(--radius-sm);
    color: white;
    background: var(--article-color);
  }

  .action-takeaway h2 {
    margin: 0 0 7px;
    font-size: 1.05rem;
  }

  .action-takeaway > div > p:last-child {
    margin: 0;
    color: var(--muted-strong);
    font-size: 0.88rem;
    line-height: 1.65;
  }

  .action-takeaway strong {
    color: var(--ink);
  }

  .source-note {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 28px;
    margin-top: 18px;
    padding: 22px 24px;
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    background: var(--surface-strong);
  }

  .source-note h2 {
    margin: 0 0 5px;
    font-size: 1rem;
  }

  .source-note p:not(.eyebrow) {
    margin: 0;
    color: var(--muted);
    font-size: 0.82rem;
  }

  .source-note .button {
    flex: 0 0 auto;
  }

  .ai-source {
    flex: 0 0 auto;
    padding: 8px 11px;
    border-radius: var(--radius-sm);
    color: var(--green-deep);
    background: var(--green-soft);
    font-size: 0.8rem;
    font-weight: 750;
  }

  .article-actions {
    position: sticky;
    top: 96px;
    padding: 25px;
    border-radius: var(--radius-md);
    background: var(--ink);
    color: white;
  }

  .article-actions .eyebrow {
    color: #93cbb3;
  }

  .article-actions > h2 {
    margin: 0;
    font-size: 1.35rem;
    line-height: 1.35;
  }

  .article-actions > p:not(.eyebrow) {
    margin: 10px 0 22px;
    color: #b8c3bd;
    font-size: 0.84rem;
  }

  .action-link {
    width: 100%;
    min-height: 68px;
    display: grid;
    grid-template-columns: 22px minmax(0, 1fr) 18px;
    align-items: center;
    gap: 10px;
    margin-top: 9px;
    padding: 10px 12px;
    border-radius: var(--radius-md);
    color: var(--ink);
    background: white;
    text-decoration: none;
    font: inherit;
    text-align: left;
    cursor: pointer;
  }

  .action-link.review {
    background: var(--yellow-soft);
  }

  .action-link.review.enrolled {
    background: var(--green-soft);
  }

  .action-link:disabled {
    cursor: wait;
    opacity: 0.62;
  }

  .action-link span {
    min-width: 0;
    display: grid;
  }

  .action-link strong {
    font-size: 0.86rem;
  }

  .action-link small {
    overflow: hidden;
    color: var(--muted);
    font-size: 0.7rem;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .learning-status {
    min-height: 18px;
    margin: 7px 2px 0;
    color: #9eaaa4;
    font-size: 0.68rem;
  }

  @media (max-width: 900px) {
    .article-grid {
      grid-template-columns: 1fr;
    }

    .article-actions {
      position: static;
    }
  }

  @media (max-width: 640px) {
    .article-shell {
      padding-top: 20px;
    }

    .article-header {
      margin: 40px auto 34px;
      text-align: left;
    }

    .article-header h1 {
      font-size: 2rem;
    }

    .article-meta {
      justify-content: flex-start;
      flex-wrap: wrap;
    }

    .card-news-section {
      margin-bottom: 42px;
    }

    .visual-guide-section {
      margin-bottom: 42px;
    }

    .comic-grid {
      grid-template-columns: 1fr;
    }

    .comic-panel {
      min-height: 250px;
      grid-template-columns: 112px minmax(0, 1fr);
    }

    .comic-visual {
      padding: 18px 12px 30px;
    }

    .comic-speech {
      margin: 16px;
      padding: 16px;
    }

    .card-news-toolbar {
      align-items: center;
    }

    .card-news-toolbar h2 {
      font-size: 1.08rem;
    }

    .carousel-count {
      display: none;
    }

    .carousel-controls .icon-button {
      width: 38px;
      height: 38px;
      flex-basis: 38px;
    }

    .card-news {
      min-height: 320px;
      flex-basis: 88%;
      padding: 24px;
    }

    .article-body {
      padding: 26px 22px;
    }

    .deep-read-section p {
      font-size: 0.96rem;
      line-height: 1.82;
    }

    .action-takeaway {
      grid-template-columns: 38px minmax(0, 1fr);
      padding: 18px;
    }

    .action-icon {
      width: 38px;
      height: 38px;
    }

    .source-note {
      align-items: stretch;
      flex-direction: column;
    }

    .source-note .button,
    .ai-source {
      width: 100%;
      text-align: center;
    }
  }
</style>

<script>
  import { getAnonymousUserId } from "../../lib/anonymous-user";

  const learningButton = document.querySelector<HTMLButtonElement>("#learning-button");
  const learningLabel = document.querySelector<HTMLElement>("#learning-label");
  const learningDescription = document.querySelector<HTMLElement>("#learning-description");
  const learningStatus = document.querySelector<HTMLElement>("#learning-status");
  const learningUserId = getAnonymousUserId();
  let learningEnrolled = false;

  function renderLearningState(enrolled: boolean) {
    learningEnrolled = enrolled;
    if (!learningButton || !learningLabel || !learningDescription) return;
    learningButton.disabled = false;
    learningButton.classList.toggle("enrolled", enrolled);
    learningLabel.textContent = enrolled ? "복습으로 이동" : "복습에 담기";
    learningDescription.textContent = enrolled
      ? "이 글이 내 복습 카드에 담겨 있어요"
      : "이 글의 퀴즈만 내 복습에 추가해요";
  }

  async function initializeLearningState() {
    const contentItemId = Number(learningButton?.dataset.contentId);
    if (!learningButton || !Number.isInteger(contentItemId)) return;
    try {
      const response = await fetch(`/api/learning/${contentItemId}?userId=${encodeURIComponent(learningUserId)}`);
      if (!response.ok) throw new Error();
      const result = await response.json() as { enrolled?: boolean };
      renderLearningState(result.enrolled === true);
    } catch {
      renderLearningState(false);
      if (learningStatus) learningStatus.textContent = "복습 상태를 확인하지 못했어요. 다시 눌러 시도할 수 있어요.";
    }
  }

  learningButton?.addEventListener("click", async () => {
    if (learningEnrolled) {
      window.location.href = "/review";
      return;
    }

    const contentItemId = Number(learningButton.dataset.contentId);
    learningButton.disabled = true;
    if (learningStatus) learningStatus.textContent = "복습 카드에 담는 중이에요.";
    try {
      const response = await fetch(`/api/learning/${contentItemId}`, {
        method: "POST",
        headers: { "content-type": "application/json", accept: "application/json" },
        body: JSON.stringify({ userId: learningUserId }),
      });
      const result = await response.json() as { error?: string };
      if (!response.ok) throw new Error(result.error ?? "복습에 담지 못했습니다.");
      renderLearningState(true);
      if (learningStatus) learningStatus.textContent = "등록했어요. 이제 이 글의 퀴즈만 복습에 나타납니다.";
    } catch (error) {
      renderLearningState(false);
      if (learningStatus) learningStatus.textContent = error instanceof Error ? error.message : "잠시 후 다시 시도해주세요.";
    }
  });

  void initializeLearningState();

  const track = document.querySelector<HTMLElement>("#card-news-track");

  if (track) {
    const slides = Array.from(track.querySelectorAll<HTMLElement>("[data-slide-index]"));
    const dots = Array.from(document.querySelectorAll<HTMLButtonElement>("[data-slide-target]"));
    const previous = document.querySelector<HTMLButtonElement>("#previous-card");
    const next = document.querySelector<HTMLButtonElement>("#next-card");
    const currentLabel = document.querySelector<HTMLElement>("#current-slide");
    let currentIndex = 0;

    const updateControls = (index: number) => {
      currentIndex = Math.min(Math.max(index, 0), slides.length - 1);
      if (currentLabel) currentLabel.textContent = String(currentIndex + 1);
      if (previous) previous.disabled = currentIndex === 0;
      if (next) next.disabled = currentIndex === slides.length - 1;
      dots.forEach((dot, dotIndex) => {
        const active = dotIndex === currentIndex;
        dot.classList.toggle("active", active);
        if (active) dot.setAttribute("aria-current", "true");
        else dot.removeAttribute("aria-current");
      });
    };

    const goTo = (index: number) => {
      const target = slides[Math.min(Math.max(index, 0), slides.length - 1)];
      if (!target) return;
      track.scrollTo({ left: target.offsetLeft - track.offsetLeft, behavior: "smooth" });
      updateControls(index);
    };

    previous?.addEventListener("click", () => goTo(currentIndex - 1));
    next?.addEventListener("click", () => goTo(currentIndex + 1));
    dots.forEach((dot) => dot.addEventListener("click", () => goTo(Number(dot.dataset.slideTarget))));

    let scrollTimer = 0;
    track.addEventListener("scroll", () => {
      window.clearTimeout(scrollTimer);
      scrollTimer = window.setTimeout(() => {
        const nearest = slides.reduce((best, slide, index) => {
          const distance = Math.abs(slide.offsetLeft - track.offsetLeft - track.scrollLeft);
          return distance < best.distance ? { index, distance } : best;
        }, { index: 0, distance: Number.POSITIVE_INFINITY });
        updateControls(nearest.index);
      }, 80);
    }, { passive: true });

    updateControls(0);
  }
</script>
