{
	"$schema": "../../node_modules/wrangler/config-schema.json",
	"name": "life-quiz-ingest",
	"main": "src/index.ts",
	"compatibility_date": "2026-06-27",
	"compatibility_flags": ["nodejs_compat"],
	"workers_dev": false,
	"vars": {
		"GEMINI_MODEL": "gemini-3.1-flash-lite",
		"GEMINI_RPM_BUDGET": "12",
		"GEMINI_INGEST_MIN_INTERVAL_MS": "8000",
		"NOTION_PAGE_ID": "38ccb889-5490-8102-93b1-c63f45626a20"
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "life-quiz-db",
			"database_id": "31dea428-bbf0-4e8d-a8c8-816e2b2a970c"
		}
	],
	"triggers": {
		"crons": [
			"0 3 * * *",
			"0 9 * * *",
			"0 15 * * *",
			"0 21 * * *"
		]
	},
	"observability": {
		"enabled": true,
		"logs": { "head_sampling_rate": 1 },
		"traces": { "enabled": true, "head_sampling_rate": 0.05 }
	}
}
