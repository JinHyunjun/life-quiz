{
	"$schema": "../../node_modules/wrangler/config-schema.json",
	"name": "life-quiz-ingest",
	"main": "src/index.ts",
	"compatibility_date": "2026-06-26",
	"vars": {
		"GEMINI_MODEL": "gemini-3-flash-preview"
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "life-quiz-db",
			"database_id": "31dea428-bbf0-4e8d-a8c8-816e2b2a970c"
		}
	],
	"triggers": {
		"crons": ["0 21 * * *"]
	},
	"observability": {
		"enabled": true
	}
}
